end

local function IsRagdolled(humanoid)
    if not humanoid then return true end
    local state = humanoid:GetState()
    return state == Enum.HumanoidStateType.Ragdoll or state == Enum.HumanoidStateType.Physics or state == Enum.HumanoidStateType.FallingDown or state == Enum.HumanoidStateType.Dead
end

