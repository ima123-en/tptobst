local function IsAlive()
    local c = LP.Character
    if not c then return false end
    local h   = c:FindFirstChildOfClass("Humanoid")
    local hrp = c:FindFirstChild("HumanoidRootPart")
    return h and h.Health > 0 and hrp ~= nil
end

local function IsRagdolled(h)
    if not h then return true end
    local s = h:GetState()
    return s == Enum.HumanoidStateType.Ragdoll
        or s == Enum.HumanoidStateType.Physics
        or s == Enum.HumanoidStateType.FallingDown
        or s == Enum.HumanoidStateType.Dead
end

local function IsUnderRoof()
    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    if not hrp then return true end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {c, Workspace.CurrentCamera}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ray = Workspace:Raycast(hrp.Position, Vector3.new(0, 100, 0), params)
    return ray and ray.Instance and ray.Instance.CanCollide or false
end

local function IsHoldingBrainrot()
    local c = LP.Character
    if not c then return false end
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and t.Name ~= CARPET_NAME and t.Name ~= TOOL_NAME then
            return true
        end
    end
    return false
end

local function PlaySound(id)
    task.spawn(function()
        local snd = Instance.new("Sound")
        snd.SoundId = "rbxassetid://" .. id
        snd.Volume  = 0.3
        snd.Parent  = Workspace
        snd:Play()
        snd.Ended:Wait()
        snd:Destroy()
    end)
end

local function ShowNotification(text, customColor)
    local NotificationGui = PlayerGui:FindFirstChild("TPNotification")
    if not NotificationGui then
        NotificationGui = Instance.new("ScreenGui")
        NotificationGui.Name           = "TPNotification"
        NotificationGui.ResetOnSpawn   = false
        NotificationGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        NotificationGui.DisplayOrder   = 999
        NotificationGui.Parent         = PlayerGui

        local frame = Instance.new("Frame")
        frame.Name                   = "Frame"
        frame.Size                   = UDim2.new(0, 350, 0, 70)
        frame.Position               = UDim2.new(0.5, -175, 0.08, 0)
        frame.BackgroundColor3       = Color3.fromRGB(0, 0, 0)
        frame.BorderSizePixel        = 0
        frame.BackgroundTransparency = 1
        frame.Visible                = false
        frame.Parent                 = NotificationGui
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)

        local label = Instance.new("TextLabel")
        label.Name                   = "Text"
        label.Size                   = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3             = Color3.fromRGB(255, 255, 255)
        label.Font                   = Enum.Font.GothamBold
        label.TextSize               = 22
        label.Parent                 = frame
    end

    local NotifFrame = NotificationGui:FindFirstChild("Frame")
    local NotifText  = NotifFrame and NotifFrame:FindFirstChild("Text")
    if not NotifFrame or not NotifText then return end

    NotifFrame.Visible               = true
    NotifFrame.BackgroundTransparency = 0
    NotifText.Text                   = text
    NotifText.TextTransparency       = 0
    NotifText.TextColor3             = customColor or Color3.fromRGB(255, 255, 255)

    task.spawn(function()
        local startTime = tick()
        while tick() - startTime < 4 do
            for i = 0, 1, 0.05 do
                if not NotifFrame.Visible then break end
                local brightness = 1 - (math.sin(i * math.pi) * 0.4)
                if not customColor then
                    NotifText.TextColor3 = Color3.fromRGB(
                        255 * brightness, 255 * brightness, 255 * brightness
                    )
                end
                task.wait(0.03)
            end
        end
        for i = 0, 1, 0.05 do
            NotifFrame.BackgroundTransparency = i
            NotifText.TextTransparency        = i
            task.wait(0.02)
        end
        NotifFrame.Visible = false
    end)
end

local function findAdorneeGlobal(animalData)
    if not animalData then return nil end
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    local plot = plots:FindFirstChild(animalData.plot)
    if plot then
        local podiums = plot:FindFirstChild("AnimalPodiums")
        if podiums then
            local podium = podiums:FindFirstChild(animalData.slot)
            if podium then
                local base = podium:FindFirstChild("Base")
                if base then
                    local spawn = base:FindFirstChild("Spawn")
                    if spawn then return spawn end
                    return base:FindFirstChildWhichIsA("BasePart") or base
                end
            end
        end
    end
    return nil
end

local function Equip(name)
    if not IsAlive() then return false end
    local c    = LP.Character
    local hum  = c and c:FindFirstChildOfClass("Humanoid")
    local tool = LP.Backpack:FindFirstChild(name) or (c and c:FindFirstChild(name))
    if hum and tool then hum:EquipTool(tool) return true end
    return false
end

_G._isTargetPlotUnlocked = function(plotName)
    local ok, res = pcall(function()
        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return false end
        local targetPlot = plots:FindFirstChild(plotName)
        if not targetPlot then return false end
        local unlockFolder = targetPlot:FindFirstChild("Unlock")
        if not unlockFolder then return true end
        local unlockItems = {}
        for _, item in pairs(unlockFolder:GetChildren()) do
            local pos = nil
            if item:IsA("Model") then
                pcall(function() pos = item:GetPivot().Position end)
            elseif item:IsA("BasePart") then
                pos = item.Position
            end
            if pos then
                table.insert(unlockItems, {Object = item, Height = pos.Y})
            end
        end
        table.sort(unlockItems, function(a, b) return a.Height < b.Height end)
        if #unlockItems == 0 then return true end
        local floor1Door = unlockItems[1].Object
        for _, desc in ipairs(floor1Door:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then return false end
        end
        for _, child in ipairs(floor1Door:GetChildren()) do
            if child:IsA("ProximityPrompt") and child.Enabled then return false end
        end
        return true
    end)
    return ok and res or false
end

local function getClosestBaseIdx(pos)
    local closest, dist = 1, math.huge
    for i, basePos in pairs(BASES_LOW) do
        local d = (Vector2.new(pos.X, pos.Z) - Vector2.new(basePos.X, basePos.Z)).Magnitude
        if d < dist then dist = d; closest = i end
    end
    return closest
end

local function GetBestTarget()
    local t0 = tick()
    local PS = getgenv().PrioritySystem
    while (not PS or not PS.SelectedData or not PS.SelectedData.plot or not PS.SelectedData.slot)
        and tick() - t0 < 1.5 do
        task.wait(0.05)
        PS = getgenv().PrioritySystem
    end
    if not PS or not PS.SelectedData or not PS.SelectedData.plot or not PS.SelectedData.slot then
        return nil, nil
    end
    local sel        = PS.SelectedData
    local targetPart = findAdorneeGlobal(sel)
    if not targetPart then return nil, nil end
    return sel, targetPart
end

local function walkForward(seconds)
    local char = LP.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not (char and hum and hrp) then return end
    local playerScripts = LP:WaitForChild("PlayerScripts")
    local playerModule  = require(playerScripts:WaitForChild("PlayerModule"))
    local Controls      = playerModule:GetControls()
    local lookVector    = hrp.CFrame.LookVector
    Controls:Disable()
    local startTime = os.clock()
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if os.clock() - startTime >= seconds then
            conn:Disconnect()
            hum:Move(Vector3.zero, false)
            Controls:Enable()
            return
        end
        hum:Move(lookVector, false)
    end)
end

local function waitForClone(timeoutSecs)
    local cloneName = tostring(LP.UserId) .. "_Clone"
    if Workspace:FindFirstChild(cloneName) then return true end
    local found = false
    local conn
    local timer = task.delay(timeoutSecs, function()
        if conn then conn:Disconnect() end
    end)
    conn = Workspace.ChildAdded:Connect(function(child)
        if child.Name == cloneName then
            found = true
            task.cancel(timer)
            conn:Disconnect()
        end
    end)
    local deadline = tick() + timeoutSecs
    while not found and tick() < deadline do
        task.wait(0.05)
    end
    pcall(function() conn:Disconnect() end)
    return found
end

local function clickTpButton(tpButton)
    tpButton.Visible = true
    if Settings.CloneMode == "Good" and typeof(firesignal) == "function" then
        pcall(function()
            firesignal(tpButton.MouseButton1Click)
            firesignal(tpButton.MouseButton1Up)
            firesignal(tpButton.MouseButton1Down)
        end)
    else
        local inset = GuiService:GetGuiInset()
        local pos   = tpButton.AbsolutePosition + tpButton.AbsoluteSize * 0.5
        VirtualInputManager:SendMouseButtonEvent(pos.X + inset.X, pos.Y + inset.Y, 0, true,  game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(pos.X + inset.X, pos.Y + inset.Y, 0, false, game, 1)
    end
end

local function instantClone()
    if _G.isCloning then return false end
    _G.isCloning = true
    local success = false
    pcall(function()
        local char = LP.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not (char and hum) then return end
        local cloner = LP.Backpack:FindFirstChild(TOOL_NAME) or char:FindFirstChild(TOOL_NAME)
        if not cloner then return end
        pcall(function() hum:EquipTool(cloner) end)
        task.wait(0.1)
        pcall(function() cloner:Activate() end)
        task.wait(0.1)
        local cloneFound = waitForClone(5)
        if not cloneFound then return end
        local tpButton = nil
        local deadline = tick() + 2
        while tick() < deadline do
            local tf  = PlayerGui:FindFirstChild("ToolsFrames")
            local qcf = tf and tf:FindFirstChild("QuantumCloner")
            local btn = qcf and qcf:FindFirstChild("TeleportToClone")
            if btn then tpButton = btn break end
            task.wait(0.05)
        end
        if not tpButton then return end
        clickTpButton(tpButton)
        success = true
    end)
    _G.isCloning = false
    return success
end

local function PerformVelocityFloat(targetPart, ignoreRagdoll)
    if not IsAlive() then return end
    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    local hum = c and c:FindFirstChildOfClass("Humanoid")
    if not hrp or not targetPart or not hum then return end
    if not ignoreRagdoll and IsRagdolled(hum) then return end
    local petPos = targetPart.Position
    hrp.CFrame = CFrame.new(Vector3.new(petPos.X, hrp.Position.Y, petPos.Z))
    task.wait(0.1)
    if not IsAlive() or (not ignoreRagdoll and IsRagdolled(hum)) then return end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {c, Workspace.CurrentCamera}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local targetY    = petPos.Y
    local floatStart = tick()
    while tick() - floatStart < 4 do
        if not IsAlive() or (not ignoreRagdoll and IsRagdolled(hum)) then break end
        if IsHoldingBrainrot() or LP:GetAttribute("Stealing") then break end
        if hrp.Position.Y >= targetY then hrp.AssemblyLinearVelocity = Vector3.zero break end
        local head = c:FindFirstChild("Head") or hrp
        local ray  = Workspace:Raycast(head.Position, Vector3.new(0, 3, 0), params)
        if ray and ray.Instance and ray.Instance.CanCollide then
            hrp.AssemblyLinearVelocity = Vector3.zero break
        end
        hrp.AssemblyLinearVelocity = Vector3.new(0, 35, 0)
        RunService.Heartbeat:Wait()
    end
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end

local function TeleportToBrainrot(ignoreRagdoll)
    if not IsAlive() then return end
    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    local hum = c and c:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    if not ignoreRagdoll and IsRagdolled(hum) then return end
    if IsHoldingBrainrot() or LP:GetAttribute("Stealing") then return end
    local targetData, targetPart = GetBestTarget()
    if not targetPart then return end
    PlaySound("131661992591924")
    Equip(CARPET_NAME)
    task.wait(0.1)
    if not IsAlive() then return end
    if not ignoreRagdoll and IsRagdolled(hum) then return end
    hrp.AssemblyLinearVelocity  = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    hrp.Anchored = true
    task.wait(0.05)
    hrp.Anchored = false
    PerformVelocityFloat(targetPart, ignoreRagdoll)
    if hum and IsAlive() then hum.HipHeight = savedHipHeight end
end

local function TriggerTpAfterHit()
    if not Settings.TpAfterHit then return end
    if not AllowTpAfterRagdoll then return end
    if isTpMoving then return end
    if not IsAlive() then return end
    local now = tick()
    if now - LastRagdollTime < RagdollCooldown then return end
    LastRagdollTime = now
    task.delay(0.15, function()
        if not IsAlive() then return end
        local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if h and IsRagdolled(h) then
            pcall(function() h:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        end
        TeleportToBrainrot(true)
    end)
end

local function OnCharacterSpawn(char)
    LastRagdollTime     = 0
    AllowTpAfterRagdoll = false
    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        savedHipHeight = hum.HipHeight
        hum.StateChanged:Connect(function(_, new)
            if new == Enum.HumanoidStateType.Ragdoll
            or new == Enum.HumanoidStateType.FallingDown
            or new == Enum.HumanoidStateType.Physics then
                TriggerTpAfterHit()
            end
        end)
    end
    task.delay(1.5, function()
        if LP.Character == char then AllowTpAfterRagdoll = true end
    end)
end
LP.CharacterAdded:Connect(OnCharacterSpawn)
if LP.Character then OnCharacterSpawn(LP.Character) end

LP:GetAttributeChangedSignal("RagdollEndTime"):Connect(function()
    TriggerTpAfterHit()
end)

local function runAutoSnipe()
    if isTpMoving then return end
    local char = LP.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not IsAlive() then return end
    if IsRagdolled(hum) then return end
    if IsUnderRoof() then
        ShowNotification("Ceiling detected! Move outside.", Color3.fromRGB(255, 80, 80))
        return
    end
    local targetPetData, targetPart = GetBestTarget()
    if not targetPart or not targetPetData then
        ShowNotification("No Priority target found.", Color3.fromRGB(255, 80, 80))
        return
    end
    isTpMoving = true
    PlaySound("131661992591924")
    if targetPetData.name then
        ShowNotification(tostring(targetPetData.name) .. " detected!")
    end
    local exactPos = targetPart.Position
    local carpet   = LP.Backpack:FindFirstChild(CARPET_NAME) or char:FindFirstChild(CARPET_NAME)
    if carpet then hum:EquipTool(carpet) end
    task.wait(0.01)
    if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
    local isSecondFloor = exactPos.Y > 10
    local plotIndex     = getClosestBaseIdx(exactPos)
    local targetBasePos = isSecondFloor and BASES_HIGH[plotIndex] or BASES_LOW[plotIndex]
    local targetHeight  = math.max(targetBasePos.Y, 50)
    local jumpStart = tick()
    while hrp.Position.Y < targetHeight and (tick() - jumpStart) < 3 do
        if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 200, hrp.AssemblyLinearVelocity.Z)
        RunService.Heartbeat:Wait()
    end
    for i = 1, 10 do
        if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
        if (hrp.Position - targetBasePos).Magnitude > 3 then
            hrp.CFrame = CFrame.new(targetBasePos)
            task.wait(0.05)
        end
    end
    if not isSecondFloor then
        local bestSpot = CLONE_POSITIONS_FLOOR[1]
        local minDst   = math.huge
        for _, v in ipairs(CLONE_POSITIONS_FLOOR) do
            local d = (targetPart.Position - v).Magnitude
            if d < minDst then minDst = d; bestSpot = v end
        end
        for i = 1, 6 do
            if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
            if (hrp.Position - bestSpot).Magnitude > 3 then
                hrp.CFrame = CFrame.new(bestSpot)
                task.wait(0.05)
            end
        end
    end
    local bestFace    = FACE_TARGETS[1]
    local minFaceDist = math.huge
    for _, v in ipairs(FACE_TARGETS) do
        local d = (hrp.Position - v).Magnitude
        if d < minFaceDist then minFaceDist = d; bestFace = v end
    end
    task.wait(0.1)
    if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(bestFace.X, hrp.Position.Y, bestFace.Z))
    if isSecondFloor or not _G._isTargetPlotUnlocked(targetPetData.plot) then
        if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
        walkForward(0.4)
        task.wait(0.4)
        if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
        instantClone()
        task.wait(0.3)
    end
    if not IsAlive() or IsRagdolled(hum) then isTpMoving = false return end
    if carpet then hum:EquipTool(carpet) end
    local verticalDiff = targetPart.Position.Y - hrp.Position.Y
    if verticalDiff > 2 then
        local airPos = Vector3.new(targetPart.Position.X, targetPart.Position.Y - 8, targetPart.Position.Z)
        local plat = Instance.new("Part")
        plat.Name = "XiTempPlatform"; plat.Size = Vector3.new(3, 1, 3)
        plat.Position = airPos - Vector3.new(0, 5, 0); plat.Color = Color3.new(1, 0, 0)
        plat.Material = Enum.Material.Neon; plat.Anchored = true
        plat.CanCollide = true; plat.Transparency = 0.3; plat.Parent = Workspace
        RunService.Heartbeat:Wait()
        for i = 1, 10 do
            if not IsAlive() or IsRagdolled(hum) then break end
            if not LP:GetAttribute("Stealing") then
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                hrp.CFrame = CFrame.new(airPos)
                task.wait(0.05)
            end
        end
        task.spawn(function()
            local start = tick()
            while tick() - start < 20 do
                if LP:GetAttribute("Stealing") then break end
                if not IsAlive() then break end
                task.wait(0.1)
            end
            plat:Destroy()
        end)
    else
        for i = 1, 10 do
            if not IsAlive() or IsRagdolled(hum) then break end
            if LP:GetAttribute("Stealing") then break end
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
            if (hrp.Position - targetPart.Position).Magnitude > 3 then
                hrp.CFrame = CFrame.new(targetPart.Position)
                task.wait(0.05)
            end
            task.wait(0.05)
        end
    end
    isTpMoving = false
end

