local function OnCharacterSpawn(char)
    LastRagdollTime = 0
    WasRagdolledLastFrame = false
    AllowTpAfterRagdoll = false
    floatAbort = true
    isFloating = false

    local hum = char:WaitForChild("Humanoid", 5)
    if hum then savedHipHeight = hum.HipHeight end

    char.ChildAdded:Connect(OnBrainrotToolAdded)

    task.delay(1.5, function()
        if LP.Character == char then AllowTpAfterRagdoll = true end
    end)
end

