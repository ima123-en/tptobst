    -- Small delay to let everything load
    task.wait(1)
    
    -- Check if AutoTp is enabled
    if Settings.AutoTp then
        -- Get the target to show in notification
        local _, _, _, petName = GetBestTarget(true)
        
        if petName then
            -- Execute with notification
            ExecuteFlow(true)
        end
    end
end)
