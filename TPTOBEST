local function TriggerTpAfterHit()
    if not Settings.TpAfterHit then return end
    if not AllowTpAfterRagdoll then return end
    if isRunning or swapMonitorActive or isTpMoving then return end
    if not IsAlive() then return end

    local now = tick()
    if now - LastRagdollTime < RagdollCooldown then return end
    LastRagdollTime = now

    task.delay(0.15, function()
        if not IsAlive() then return end
        local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if h and IsRagdolled(h) then
            pcall(function() h:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        end
        TeleportToBrainrot(true)
    end)
end

local function OnCharacterSpawn(char)
    LastRagdollTime        = 0
    AllowTpAfterRagdoll    = false
    local hum              = char:WaitForChild("Humanoid", 5)
    if hum then 
        savedHipHeight = hum.HipHeight
        hum.StateChanged:Connect(function(_, new)
            if new == Enum.HumanoidStateType.Ragdoll
            or new == Enum.HumanoidStateType.FallingDown
            or new == Enum.HumanoidStateType.Physics then
                TriggerTpAfterHit()
            end
        end)
    end
    task.delay(1.5, function()
        if LP.Character == char then AllowTpAfterRagdoll = true end
    end)
end
LP.CharacterAdded:Connect(OnCharacterSpawn)
if LP.Character then OnCharacterSpawn(LP.Character) end

LP:GetAttributeChangedSignal("RagdollEndTime"):Connect(function()
    TriggerTpAfterHit()
end)

local function StartSwapMonitor()
    if not IsAlive() then return end
    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    posBeforeSwap     = hrp.Position
    savedYPosition    = hrp.Position.Y  
    swapMonitorActive = true

    task.spawn(function()
        local timeout = tick() + 30
        while swapMonitorActive and tick() < timeout do
            task.wait(0.05)
            if not IsAlive() then swapMonitorActive = false return end
            c   = LP.Character
            hrp = c and c:FindFirstChild("HumanoidRootPart")
            if not hrp then break end

            local dist = (hrp.Position - posBeforeSwap).Magnitude
            if dist > 5 then
                swapMonitorActive = false
                local currentPos  = hrp.Position
                hrp.CFrame        = CFrame.new(Vector3.new(currentPos.X, savedYPosition, currentPos.Z))
                hrp.AssemblyLinearVelocity  = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                hrp.Anchored = true 
                task.wait(0.3) 
                if not IsAlive() then return end
                hrp.Anchored = false
                TeleportToBrainrot()
                return
            end
        end
        swapMonitorActive = false
    end)
end

