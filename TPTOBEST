-------------------------------------------------
-- Input
-------------------------------------------------

local TpKeyCode             = Enum.KeyCode[Settings.TpKey] or Enum.KeyCode.T
local TpBrainrotKeyCode     = Enum.KeyCode[Settings.TpToBrainrotKey] or Enum.KeyCode.G
local waitingForTpKeybind   = false
local waitingForBrainrotKey = false

KeybindButton.MouseButton1Click:Connect(function()
    waitingForTpKeybind = true; waitingForBrainrotKey = false
    KeybindButton.Text = "..."; KeybindButton.TextColor3 = Color3.fromRGB(0,255,255)
end)
BrainrotKeyButton.MouseButton1Click:Connect(function()
    waitingForBrainrotKey = true; waitingForTpKeybind = false
    BrainrotKeyButton.Text = "..."; BrainrotKeyButton.TextColor3 = Color3.fromRGB(0,255,255)
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if waitingForTpKeybind and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForTpKeybind = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            Settings.TpKey = keyName; TpKeyCode = input.KeyCode
            KeybindButton.Text = keyName; KeybindButton.TextColor3 = Color3.fromRGB(200,200,210)
            TpButton.Text = "Teleport to Best (Key: " .. keyName .. ")"
            SaveSettings()
        else
            KeybindButton.Text = Settings.TpKey or "T"; KeybindButton.TextColor3 = Color3.fromRGB(200,200,210)
        end
        return
    end
    if waitingForBrainrotKey and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForBrainrotKey = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            Settings.TpToBrainrotKey = keyName; TpBrainrotKeyCode = input.KeyCode
            BrainrotKeyButton.Text = keyName; BrainrotKeyButton.TextColor3 = Color3.fromRGB(200,200,210)
            SaveSettings()
        else
            BrainrotKeyButton.Text = Settings.TpToBrainrotKey or "G"; BrainrotKeyButton.TextColor3 = Color3.fromRGB(200,200,210)
        end
        return
    end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode == TpKeyCode then
        task.spawn(runAutoSnipe)
    elseif input.KeyCode == TpBrainrotKeyCode then
        task.spawn(function() TeleportToBrainrot() end)
    end
end)

-- Status loop
local hadPriorityLast = true
task.spawn(function()
    while Main.Parent do
        local PS          = getgenv().PrioritySystem
        local sel         = PS and PS.SelectedData
        local hasPriority = sel and sel.name ~= nil
        if hasPriority then
            PriorityStatus.Text       = "→ " .. tostring(sel.name)
            PriorityStatus.TextColor3 = Color3.fromRGB(100, 200, 100)
        else
            PriorityStatus.Text       = "No Priority Selected."
            PriorityStatus.TextColor3 = Color3.fromRGB(200, 100, 100)
            if hadPriorityLast then PlaySound("130511970684019") end
        end
        hadPriorityLast = hasPriority
        if isTpMoving then
            StatusText.Text = "Running"; StatusDot.BackgroundColor3 = Color3.fromRGB(180,180,190)
        else
            StatusText.Text = "Idle";    StatusDot.BackgroundColor3 = Color3.fromRGB(100,100,110)
        end
        task.wait(1)
    end
end)

-- Drag
local dragging, dragStart, startPos
Main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1
    or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = i.Position; startPos = Main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+delta.X, startPos.Y.Scale, startPos.Y.Offset+delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1
    or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

