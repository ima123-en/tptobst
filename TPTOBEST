local function ExecuteFlow(showNotification, isManual)
    if isRunning or isTpMoving then return end
    if not IsAlive() then return end

    local Char = LP.Character
    local Hum  = Char and Char:FindFirstChildOfClass("Humanoid")
    local HRP  = Char and Char:FindFirstChild("HumanoidRootPart")
    if IsRagdolled(Hum) then return end

    if IsUnderRoof() then
        if isManual then
            ShowNotification("Ceiling detected! Move outside.", Color3.fromRGB(255, 80, 80))
        end
        return
    end

    isRunning  = true
    isTpMoving = true

    if Settings.AutoTp then
        local targetPetData, targetPart, isPriority = GetBestTarget()
        if not targetPart then isRunning = false; isTpMoving = false; return end

        if isPriority then
            PlaySound("131661992591924")
        else
            PlaySound("91271439961236")
        end

        if showNotification and targetPetData and targetPetData.name then
            local duelSuffix = ""
            if IsBrainrotInDuel(targetPetData) then duelSuffix = " (Duel)" end
            ShowNotification(targetPetData.name .. duelSuffix .. " detected!")
        end

        local exactPos = targetPart.Position
        local carpet   = LP.Backpack:FindFirstChild(CARPET_NAME) or Char:FindFirstChild(CARPET_NAME)
        if carpet then Hum:EquipTool(carpet) end
        task.wait(0.01)
        if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end

        local isSecondFloor = exactPos.Y > 10
        local plotIndex     = getClosestBaseIdx(exactPos)
        local targetBasePos = isSecondFloor and BASES_HIGH[plotIndex] or BASES_LOW[plotIndex]
        local minHeight     = 50
        local targetHeight  = math.max(targetBasePos.Y, minHeight)
        savedYPosition      = targetHeight  

        getgenv().SMKT_DISABLE_VELOCITY = true
        local jumpStart = tick()
        while HRP.Position.Y < targetHeight and (tick() - jumpStart) < 3 do
            if not IsAlive() or IsRagdolled(Hum) then 
                isRunning = false; isTpMoving = false; getgenv().SMKT_DISABLE_VELOCITY = false
                return 
            end 
            HRP.AssemblyLinearVelocity = Vector3.new(HRP.AssemblyLinearVelocity.X, 250, HRP.AssemblyLinearVelocity.Z)
            RunService.Heartbeat:Wait()
        end
        getgenv().SMKT_DISABLE_VELOCITY = false

        for i = 1, 10 do
            if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end 
            HRP.AssemblyLinearVelocity = Vector3.new(HRP.AssemblyLinearVelocity.X, 0, HRP.AssemblyLinearVelocity.Z)
            if (HRP.Position - targetBasePos).Magnitude > 3 then
                HRP.CFrame = CFrame.new(targetBasePos)
                task.wait(0.05)
            end
        end

        if not isSecondFloor then
            local bestSpot = CLONE_POSITIONS_FLOOR[1]
            local minDst   = math.huge
            for _, v in ipairs(CLONE_POSITIONS_FLOOR) do
                local d = (targetPart.Position - v).Magnitude
                if d < minDst then minDst = d; bestSpot = v end
            end
            for i = 1, 6 do
                if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end 
                if (HRP.Position - bestSpot).Magnitude > 3 then
                    HRP.CFrame = CFrame.new(bestSpot)
                    task.wait(0.05)
                end
            end
        end

        local bestFace    = FACE_TARGETS[1]
        local minFaceDist = math.huge
        for _, v in ipairs(FACE_TARGETS) do
            if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end
            local d = (HRP.Position - v).Magnitude
            if d < minFaceDist then
                minFaceDist = d
                bestFace    = v
            end
        end

        task.wait(0.1)
        if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end
        HRP.CFrame      = CFrame.lookAt(HRP.Position, Vector3.new(bestFace.X, HRP.Position.Y, bestFace.Z))
        savedYPosition  = HRP.Position.Y  

        if isSecondFloor then
            local hit = RaycastWallFromChest(80)
            if hit then
                local hitPos  = hit.Position
                local dir     = HRP.CFrame.LookVector
                local y       = HRP.Position.Y
                local wallPos = Vector3.new(hitPos.X, y, hitPos.Z)

                HRP.CFrame = CFrame.lookAt(wallPos, wallPos + dir)

                local settleStart = tick()
                while tick() - settleStart < 0.2 do
                    if not IsAlive() or IsRagdolled(Hum) then
                        isRunning=false;isTpMoving=false;return
                    end
                    local dist = (HRP.Position - wallPos).Magnitude
                    if dist > 0.5 then
                        HRP.CFrame = CFrame.lookAt(wallPos, wallPos + dir)
                    end
                    HRP.AssemblyLinearVelocity  = Vector3.zero
                    HRP.AssemblyAngularVelocity = Vector3.zero
                    RunService.Heartbeat:Wait()
                end

                HRP.Anchored = true
                task.wait(0.02)
                HRP.Anchored = false
                if not IsAlive() or IsRagdolled(Hum) then
                    isRunning=false;isTpMoving=false;return
                end
            end
        end

        local usedClone     = false
        local didSwapInFlow = false

        if Settings.AutoClone then
            local needClone
            if isSecondFloor then
                needClone = true
            else
                needClone = QuickWallCheck(Hum, HRP)
            end

            if needClone then
                local tool = LP.Backpack:FindFirstChild(TOOL_NAME) or Char:FindFirstChild(TOOL_NAME)
                if tool then
                    Hum:EquipTool(tool)
                    task.wait(0.05)
                    if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end
                    pcall(function() tool:Activate() end)
                    usedClone = true

                    local cloneName    = tostring(LP.UserId) .. "_Clone"
                    local cloneSpawned = false
                    local waitStart    = tick()
                    while tick() - waitStart < 3 do
                        if Workspace:FindFirstChild(cloneName) then
                            cloneSpawned = true
                            break
                        end
                        task.wait(0.05)
                    end

                    if cloneSpawned then
                        local PlayerGui   = LP:WaitForChild("PlayerGui")
                        local toolsFrames = PlayerGui:FindFirstChild("ToolsFrames", 2)
                        if toolsFrames and IsAlive() and not IsRagdolled(Hum) then
                            local qcFrame  = toolsFrames:FindFirstChild("QuantumCloner", 2)
                            if qcFrame and IsAlive() and not IsRagdolled(Hum) then
                                local tpButton = qcFrame:FindFirstChild("TeleportToClone", 2)
                                if tpButton then
                                    local preSwapPos   = HRP.Position
                                    local clickTimeout = tick() + 2
                                    while tick() < clickTimeout do
                                        if not IsAlive() or IsRagdolled(Hum) then break end
                                        if (HRP.Position - preSwapPos).Magnitude > 2 then
                                            didSwapInFlow = true
                                            break
                                        end
                                        if tpButton.Visible and tpButton.AbsoluteSize.X > 0 then
                                            ClickTeleportToClone(tpButton)
                                            task.wait(0.02)
                                        else
                                            RunService.RenderStepped:Wait()
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        if isSecondFloor and didSwapInFlow then
            task.wait(0.25)
        end

        Equip(CARPET_NAME)
        task.wait(0.1)
        if not IsAlive() or IsRagdolled(Hum) then isRunning=false;isTpMoving=false;return end

        if isSecondFloor then
            local currentPos = HRP.Position
            local petPos     = targetPart.Position
            local deltaY     = math.abs(petPos.Y - currentPos.Y)
            if deltaY < 4 then
                local look  = HRP.CFrame.LookVector
                local tpPos = Vector3.new(petPos.X, currentPos.Y, petPos.Z)
                HRP.CFrame  = CFrame.new(tpPos, tpPos + look)
            else
                PerformVelocityFloat(targetPart, false)
            end
        else
            PerformVelocityFloat(targetPart, false)
        end
        
        isRunning  = false
        isTpMoving = false

        if Settings.TpToBrainrotAfter and usedClone and not didSwapInFlow and IsAlive() and not IsRagdolled(Hum) then 
            StartSwapMonitor()
        end
        return
    end

    isRunning  = false
    isTpMoving = false
end

