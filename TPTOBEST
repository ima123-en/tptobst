UpdateUILayout = function()
    local currentY = 50
    local spacing = 8

    for _, item in ipairs(UIItems) do
        if item.isSubToggle then
            if Settings[item.parentKey] then
                item.frame.Visible = true
                item.frame.Size = UDim2.new(0.85, 0, 0, item.height)
                item.frame.Position = UDim2.new(0.1, 0, 0, currentY)
                currentY = currentY + item.height + spacing
            else
                item.frame.Visible = false
            end
        else
            item.frame.Visible = true
            item.frame.Size = UDim2.new(0.9, 0, 0, item.height)
            item.frame.Position = UDim2.new(0.05, 0, 0, currentY)
            currentY = currentY + item.height + spacing
        end
    end

    KeybindFrame.Size = UDim2.new(0.9, 0, 0, 36)
    KeybindFrame.Position = UDim2.new(0.05, 0, 0, currentY)
    currentY = currentY + 36 + spacing

    Divider2.Position = UDim2.new(0.05, 0, 0, currentY)
    currentY = currentY + 11
    ManualBtn.Position = UDim2.new(0.05, 0, 0, currentY)
    currentY = currentY + 40 + 11
    StatusBar.Position = UDim2.new(0.05, 0, 0, currentY)
    currentY = currentY + 24 + 11

    Main.Size = UDim2.new(0, 270, 0, currentY)
end

-- Status update loop
task.spawn(function()
    while Main.Parent do
        local PS = getgenv().PrioritySystem
        if PS and PS.SelectedData and PS.SelectedData.name then
            PriorityStatus.Text = "→ " .. PS.SelectedData.name
            PriorityStatus.TextColor3 = Color3.fromRGB(100, 200, 100)
        else
            PriorityStatus.Text = "No target"
            PriorityStatus.TextColor3 = Color3.fromRGB(100, 100, 110)
        end
        
        if isRunning then
            StatusText.Text = "Running"
            StatusDot.BackgroundColor3 = Color3.fromRGB(180, 180, 190)
        elseif swapMonitorActive then
            StatusText.Text = "Waiting Swap..."
            StatusDot.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
        elseif isFloating then
            StatusText.Text = "Floating..."
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
        else
            StatusText.Text = "Idle"
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 100, 110)
        end
        task.wait(0.1)
    end
end)

local TpBrainrotKeyCode = Enum.KeyCode[Settings.TpToBrainrotKey] or Enum.KeyCode.G
local waitingForKeybind = false

KeybindButton.MouseButton1Click:Connect(function()
    waitingForKeybind = true
    KeybindButton.Text = "Press..."
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if waitingForKeybind and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForKeybind = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            Settings.TpToBrainrotKey = keyName
            TpBrainrotKeyCode = input.KeyCode
            KeybindButton.Text = keyName
            SaveSettings()
        else
            KeybindButton.Text = Settings.TpToBrainrotKey or "G"
        end
        return
    end

    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    if input.KeyCode == Enum.KeyCode.T then
        task.spawn(function() ExecuteFlow(false) end)
    elseif input.KeyCode == TpBrainrotKeyCode then
        TeleportToBrainrot()
    end
end)

UpdateUILayout()

-- Drag
local dragging, dragStart, startPos
Main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = i.Position
        startPos = Main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

