local function GetMyPlot()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in pairs(plots:GetChildren()) do
        for _, obj in pairs(plot:GetDescendants()) do
            if obj:IsA("TextLabel") and obj.Text and (obj.Text:find(LP.Name) or obj.Text:find(LP.DisplayName)) then
                return plot
            end
        end
    end
    return nil
end

local function GetNearestBase(pos)
    local list = (pos.Y < 5) and BASES_FLOOR or BASES_AIR
    local nearest, shortest = list[1], (pos - list[1]).Magnitude
    for i = 2, #list do
        local d = (pos - list[i]).Magnitude
        if d < shortest then shortest = d nearest = list[i] end
    end
    return nearest
end

local function GetPriorityTarget()
    local PS = getgenv().PrioritySystem
    if not PS then return nil, nil, nil end
    
    local selectedData = PS.SelectedData
    if not selectedData then return nil, nil, nil end
    if not selectedData.plot or not selectedData.slot then return nil, nil, nil end
    
    local model = nil
    if PS.GetSelectedModel then
        model = PS.GetSelectedModel()
    end
    if not model then
        model = PS.SelectedModel
    end
    
    local pos = nil
    if PS.GetWorldPosition then
        pos = PS.GetWorldPosition()
    end
    
    if not pos and model then
        local root = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
        if root then pos = root.Position end
    end
    
    if not pos then
        local plots = Workspace:FindFirstChild("Plots")
        if plots then
            local plot = plots:FindFirstChild(selectedData.plot)
            if plot then
                local podiums = plot:FindFirstChild("AnimalPodiums")
                if podiums then
                    local podium = podiums:FindFirstChild(tostring(selectedData.slot))
                    if podium then
                        pos = podium:GetPivot().Position
                        for _, child in pairs(podium:GetDescendants()) do
                            if child:IsA("Model") then
                                local root = child:FindFirstChild("HumanoidRootPart") or child.PrimaryPart
                                if root then
                                    model = child
                                    pos = root.Position
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    local name = selectedData.name or (model and model.Name) or "Unknown"
    return model, pos, name
end

local function GetBestTarget(needBase)
    local pModel, pPos, pName = GetPriorityTarget()
    if pPos then
        if needBase then
            return pModel, pPos, GetNearestBase(pPos), pName
        else
            return pModel, pPos, nil, pName
        end
    end
    
    local bestModel, bestValue, bestPos, bestName = nil, -1, nil, nil
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil, nil, nil, nil end
    local myPlot = GetMyPlot()

    for _, plot in pairs(plots:GetChildren()) do
        if plot ~= myPlot then
            for _, obj in pairs(plot:GetDescendants()) do
                if obj:IsA("Model") and Database[obj.Name] then
                    local val = Database[obj.Name]
                    if val > bestValue then
                        local root = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
                        if root then
                            bestValue = val
                            bestModel = obj
                            bestPos = root.Position
                            bestName = obj.Name
                        end
                    end
                end
            end
        end
    end

    if not bestPos then return nil, nil, nil, nil end
    if needBase then
        return bestModel, bestPos, GetNearestBase(bestPos), bestName
    end
    return bestModel, bestPos, nil, bestName
end

local function Equip(name)
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local tool = LP.Backpack:FindFirstChild(name) or (char and char:FindFirstChild(name))
    if hum and tool then hum:EquipTool(tool) return true end
    return false
end

local function InstantTeleport(hrp, targetPos, lookDir)
    hrp.CFrame = CFrame.new(targetPos, targetPos + lookDir)
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
end

local function IsRagdolled(humanoid)
    if not humanoid then return true end
    local state = humanoid:GetState()
    return state == Enum.HumanoidStateType.Ragdoll
        or state == Enum.HumanoidStateType.Physics
        or state == Enum.HumanoidStateType.FallingDown
        or state == Enum.HumanoidStateType.Dead
end

