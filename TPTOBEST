    NotifText.TextTransparency = 0
    
    PlayNotificationSound()
    
    -- Pulsing animation for 4 seconds
    task.spawn(function()
        local startTime = tick()
        local duration = 4
        
        while tick() - startTime < duration do
            -- Pulse from white to gray
            for i = 0, 1, 0.05 do
                if not NotifFrame.Visible then break end
                local brightness = 1 - (math.sin(i * math.pi) * 0.4)
                NotifText.TextColor3 = Color3.fromRGB(255 * brightness, 255 * brightness, 255 * brightness)
                task.wait(0.03)
            end
        end
        
        -- Fade out
        for i = 0, 1, 0.05 do
            NotifFrame.BackgroundTransparency = i
            NotifText.TextTransparency = i
            task.wait(0.02)
        end
        
        NotifFrame.Visible = false
    end)
end

-- ==================== TELEPORT FUNCTIONS ====================
local function TeleportToBrainrot()
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    if IsRagdolled(hum) then return end

    local _, petPos = GetBestTarget(false)
    if not petPos then return end

    Equip(CARPET_NAME)
    task.wait(0.1)

    local isThirdFloor = math.abs(petPos.Y - 31.4) <= 2

    if isThirdFloor then
        floatAbort = false
        isFloating = true

        local safePos = Vector3.new(petPos.X, 22.2, petPos.Z)
        InstantTeleport(hrp, safePos, Vector3.new(0, 0, -1))
        task.wait(0.1)

        local targetY = 31.4
        local floatSpeed = 15
        local startTime = tick()
        local maxFloatTime = 5

        while tick() - startTime < maxFloatTime do
            if floatAbort then break end

            char = LP.Character
            hrp = char and char:FindFirstChild("HumanoidRootPart")
            hum = char and char:FindFirstChildOfClass("Humanoid")

            if not hrp or not hum then break end
            if IsRagdolled(hum) then break end

            local currentY = hrp.Position.Y
            if currentY >= targetY - 0.5 then break end

            local yDiff = targetY - currentY
            local ySpeed = math.clamp(yDiff * 2, 5, floatSpeed)

            hrp.AssemblyLinearVelocity = Vector3.new(0, ySpeed, 0)
            hrp.AssemblyAngularVelocity = Vector3.zero

            RunService.Heartbeat:Wait()
        end

        isFloating = false
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
        if hum then hum.HipHeight = savedHipHeight end
        floatAbort = false
    else
        local targetPos = petPos + Vector3.new(0, 3, 0)
        InstantTeleport(hrp, targetPos, Vector3.new(0, 0, -1))
        if hum then hum.HipHeight = savedHipHeight end
    end
end

local function StartSwapMonitor()
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    posBeforeSwap = hrp.Position
    swapMonitorActive = true

    task.spawn(function()
        local timeout = tick() + 30
        while swapMonitorActive and tick() < timeout do
            task.wait(0.05)
            char = LP.Character
            hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then break end

            local dist = (hrp.Position - posBeforeSwap).Magnitude
            if dist > 2.5 then
                swapMonitorActive = false
                task.wait(0.2)
                TeleportToBrainrot()
                return
            end
        end
        swapMonitorActive = false
    end)
end

local function ExecuteFlow(showNotification)
    if isRunning then return end
    isRunning = true

    local Char = LP.Character
    local HRP = Char and Char:FindFirstChild("HumanoidRootPart")
    local Hum = Char and Char:FindFirstChildOfClass("Humanoid")
    if not HRP or not Hum then isRunning = false return end

    if Settings.AutoTp then
        local model, petPos, targetBase, petName = GetBestTarget(true)
        if not targetBase then isRunning = false return end

        -- Show notification if requested
        if showNotification and petName then
            ShowNotification(petName)
        end

        Equip(CARPET_NAME)
        savedHipHeight = Hum.HipHeight

        local tween = TweenService:Create(Hum, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {HipHeight = HIP_HEIGHT_VAL})
        tween:Play()
        tween.Completed:Wait()

        local lookDir = (targetBase.X < -410) and Vector3.new(-1, 0, 0) or Vector3.new(1, 0, 0)
        local tpPos = targetBase + Vector3.new(0, 2, 0)
        InstantTeleport(HRP, tpPos, lookDir)

        Hum.HipHeight = savedHipHeight
        HRP.AssemblyLinearVelocity = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero

        task.wait(0.15)

        if Settings.AutoWalk then
            Hum.WalkSpeed = 16
            task.wait(0.1)

            local startPos = HRP.Position
            local forwardDir = (HRP.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
            local goalPos = startPos + forwardDir * 30

            Hum:MoveTo(goalPos)

            local endTime = tick() + 0.6
            while tick() < endTime do
                if HRP.AssemblyLinearVelocity.Y > 5 then
                    HRP.AssemblyLinearVelocity = Vector3.new(HRP.AssemblyLinearVelocity.X, 0, HRP.AssemblyLinearVelocity.Z)
                end
                RunService.Heartbeat:Wait()
            end

            Hum:MoveTo(HRP.Position)
            HRP.AssemblyLinearVelocity = Vector3.zero
        end

        local usedClone = false
        local didAutoSwap = false

        if Settings.AutoClone then
            Equip(TOOL_NAME)
            task.wait(0.2)
            local tool = Char:FindFirstChild(TOOL_NAME)
            if tool then
                usedClone = true
                if Settings.AutoUseClone then
                    tool:Activate()
                    task.wait(0.3)
                end

                if Settings.AutoSwap then
                    local internalRemote = tool:FindFirstChild("RemoteEvent", true) or tool:FindFirstChild("Remote", true)
                    if internalRemote and internalRemote:IsA("RemoteEvent") then
                        pcall(function() internalRemote:FireServer() end)
                    end
                    tool:Activate()
                    task.wait(0.15)

                    if TeleportRE then
                        pcall(function() TeleportRE:FireServer() end)
                    elseif NetModule then
                        pcall(function() NetModule:RemoteEvent("QuantumCloner/OnTeleport"):FireServer() end)
                    end

                    task.wait(0.6)
                    didAutoSwap = true
                end
            end
        end

        task.wait(0.1)
        Hum.HipHeight = savedHipHeight
        HRP.AssemblyLinearVelocity = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
        isRunning = false

        if Settings.TpToBrainrotAfter then
            if usedClone and not didAutoSwap then
                StartSwapMonitor()
            else
                task.wait(0.1)
                TeleportToBrainrot()
            end
        end
        return
    end
    isRunning = false
end

RunService.Heartbeat:Connect(function()
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")

    if hum and IsRagdolled(hum) then StopFloatImmediately() end

    if not Settings.TpAfterHit then return end
    if not AllowTpAfterRagdoll then return end
    if isRunning or swapMonitorActive then return end
    if not char or not hum then WasRagdolledLastFrame = false return end

    local isNowRagdolled = IsRagdolled(hum)

    if WasRagdolledLastFrame and not isNowRagdolled then
        local now = tick()
        if now - LastRagdollTime >= RagdollCooldown then
            LastRagdollTime = now
            TeleportToBrainrot()
        end
    end

    WasRagdolledLastFrame = isNowRagdolled
end)

