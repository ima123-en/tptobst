local function PerformVelocityFloat(targetPart)
    if not IsAlive() then return end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not targetPart then return end

    getgenv().SMKT_DISABLE_VELOCITY = true

    local petPos = targetPart.Position
    local startY = hrp.Position.Y

    hrp.CFrame = CFrame.new(Vector3.new(petPos.X, startY, petPos.Z))
    task.wait(0.1)
    if not IsAlive() then getgenv().SMKT_DISABLE_VELOCITY = false; return end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, Workspace.CurrentCamera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude

    local targetY = petPos.Y
    local invisibleFloor = nil

    local floatStart = tick()
    while tick() - floatStart < 4 do
        if not IsAlive() then break end 
        if IsHoldingBrainrot() or LP:GetAttribute("Stealing") then break end

        if hrp.Position.Y >= targetY then
            hrp.AssemblyLinearVelocity = Vector3.zero
            break
        end

        local head = char:FindFirstChild("Head") or hrp
        local ray = Workspace:Raycast(head.Position, Vector3.new(0, 3, 0), raycastParams)

        if ray and ray.Instance and ray.Instance.CanCollide then
            hrp.AssemblyLinearVelocity = Vector3.zero
            invisibleFloor = Instance.new("Part")
            invisibleFloor.Size = Vector3.new(12, 1, 12)
            invisibleFloor.Position = hrp.Position - Vector3.new(0, 3.2, 0)
            invisibleFloor.Anchored = true
            invisibleFloor.Transparency = 1
            invisibleFloor.CanCollide = true
            invisibleFloor.Parent = Workspace
            break
        end

        hrp.AssemblyLinearVelocity = Vector3.new(0, 35, 0)
        RunService.Heartbeat:Wait()
    end

    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    getgenv().SMKT_DISABLE_VELOCITY = false

    if invisibleFloor then
        task.spawn(function()
            local timeout = tick() + 15
            while tick() < timeout do
                if IsHoldingBrainrot() or LP:GetAttribute("Stealing") or not IsAlive() then
                    break
                end
                task.wait(0.1)
            end
            pcall(function() invisibleFloor:Destroy() end)
        end)
    end
end

TeleportToBrainrot = function(ignoreRagdoll)
    if not IsAlive() then return end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    if not ignoreRagdoll and IsRagdolled(hum) then return end

    if IsHoldingBrainrot() or LP:GetAttribute("Stealing") then return end

    local targetData, targetPart = GetBestTarget()
    if not targetPart then return end

    savedYPosition = hrp.Position.Y
    Equip(CARPET_NAME)
    task.wait(0.1)
    if not IsAlive() then return end

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    hrp.Anchored = true
    task.wait(0.05)
    hrp.Anchored = false

    PerformVelocityFloat(targetPart)

    if hum and IsAlive() then hum.HipHeight = savedHipHeight end
end

local function StartSwapMonitor()
    if not IsAlive() then return end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    posBeforeSwap = hrp.Position
    savedYPosition = hrp.Position.Y  
    swapMonitorActive = true

    task.spawn(function()
        local timeout = tick() + 30
        while swapMonitorActive and tick() < timeout do
            task.wait(0.05)
            if not IsAlive() then swapMonitorActive = false return end
            
            char = LP.Character
            hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then break end

            local dist = (hrp.Position - posBeforeSwap).Magnitude
            if dist > 5 then
                swapMonitorActive = false
                
                local currentPos = hrp.Position
                hrp.CFrame = CFrame.new(Vector3.new(currentPos.X, savedYPosition, currentPos.Z))
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                hrp.Anchored = true 
                task.wait(0.3) 
                if not IsAlive() then return end
                hrp.Anchored = false
                
                TeleportToBrainrot()
                return
            end
        end
        swapMonitorActive = false
    end)
end

local function ExecuteFlow(showNotification, isManual)
    if isRunning or isTpMoving then return end

    if not IsAlive() then return end

    if IsUnderRoof() then
        if isManual then
            ShowNotification("Ceiling detected! Move outside.", Color3.fromRGB(255, 80, 80))
        end
        return
    end

    isRunning = true
    isTpMoving = true

    local Char = LP.Character
    local HRP = Char and Char:FindFirstChild("HumanoidRootPart")
    local Hum = Char and Char:FindFirstChildOfClass("Humanoid")

    if Settings.AutoTp then
        local targetPetData, targetPart = GetBestTarget()
        if not targetPart then isRunning = false isTpMoving = false return end

        if showNotification and targetPetData and targetPetData.name then
            ShowNotification(targetPetData.name .. " detected!")
        end

        local exactPos = targetPart.Position
        local carpetName = CARPET_NAME
        local carpet = LP.Backpack:FindFirstChild(carpetName) or Char:FindFirstChild(carpetName)

        if carpet then Hum:EquipTool(carpet) end
        task.wait(0.01)
        if not IsAlive() then isRunning = false; isTpMoving = false; return end

        local isSecondFloor = exactPos.Y > 10
        local plotIndex = getClosestBaseIdx(exactPos)
        local targetBasePos = isSecondFloor and BASES_HIGH[plotIndex] or BASES_LOW[plotIndex]
        
        local minHeight = 50
        local targetHeight = math.max(targetBasePos.Y, minHeight)

        savedYPosition = targetHeight  

        getgenv().SMKT_DISABLE_VELOCITY = true
        local jumpStart = tick()
        while HRP.Position.Y < targetHeight and (tick() - jumpStart) < 3 do
            if not IsAlive() then 
                isRunning = false; isTpMoving = false; 
                getgenv().SMKT_DISABLE_VELOCITY = false
                return 
            end 
            HRP.AssemblyLinearVelocity = Vector3.new(HRP.AssemblyLinearVelocity.X, 250, HRP.AssemblyLinearVelocity.Z)
            RunService.Heartbeat:Wait()
        end
        getgenv().SMKT_DISABLE_VELOCITY = false

        for i = 1, 10 do
            if not IsAlive() then isRunning = false; isTpMoving = false; return end 
            HRP.AssemblyLinearVelocity = Vector3.new(HRP.AssemblyLinearVelocity.X, 0, HRP.AssemblyLinearVelocity.Z)
            if (HRP.Position - targetBasePos).Magnitude > 3 then
                HRP.CFrame = CFrame.new(targetBasePos)
                task.wait(0.05)
            end
        end

        if not isSecondFloor then
            local bestSpot = CLONE_POSITIONS_FLOOR[1]
            local minDst = math.huge
            for _, v in ipairs(CLONE_POSITIONS_FLOOR) do
                local d = (targetPart.Position - v).Magnitude
                if d < minDst then minDst = d; bestSpot = v end
            end
            for i = 1, 6 do
                if not IsAlive() then isRunning = false; isTpMoving = false; return end 
                if (HRP.Position - bestSpot).Magnitude > 3 then
                    HRP.CFrame = CFrame.new(bestSpot)
                    task.wait(0.05)
                end
            end
        end

        local bestFace = FACE_TARGETS[1]
        local minFaceDist = math.huge
        for _, v in ipairs(FACE_TARGETS) do
            if not IsAlive() then isRunning = false; isTpMoving = false; return end
            local d = (HRP.Position - v).Magnitude
            if d < minFaceDist then
                minFaceDist = d
                bestFace = v
            end
        end

        task.wait(0.1)
        if not IsAlive() then isRunning = false; isTpMoving = false; return end
        HRP.CFrame = CFrame.lookAt(HRP.Position, Vector3.new(bestFace.X, HRP.Position.Y, bestFace.Z))
        
        savedYPosition = HRP.Position.Y  
        
        local usedClone = false
        local didSwapInFlow = false

        if Settings.AutoClone then
            local skipClone = false

            if isSecondFloor then
                -- HIGH BASE: Wand ist IMMER da.
                walkForward(0.4)
                task.wait(0.4)
                if not IsAlive() then isRunning = false; isTpMoving = false; return end
                skipClone = false
            else
                -- LOW BASE: Wir testen ob eine Wand da ist (0.6s laufen)
                local posBeforeWalk = HRP.Position
                walkForward(0.6)
                task.wait(0.65)
                if not IsAlive() then isRunning = false; isTpMoving = false; return end
                
                local walkedDist = (HRP.Position - posBeforeWalk).Magnitude
                if walkedDist > 7 then
                    skipClone = true -- Wand offen -> Klon überspringen
                else
                    skipClone = false -- Wand zu -> Klonen!
                end
            end

            if not skipClone then
                local tool = LP.Backpack:FindFirstChild("Quantum Cloner") or Char:FindFirstChild("Quantum Cloner")

                if tool then
                    Hum:EquipTool(tool)
                    task.wait(0.5)
                    if not IsAlive() then isRunning = false; isTpMoving = false; return end
                    
                    -- Klon spawnen (Sicherheits-Upgrade: Wir benutzen das interne Activate UND die Maus)
                    pcall(function() tool:Activate() end)
                    task.wait(0.1)
                    
                    local cam = workspace.CurrentCamera
                    local centerX = cam.ViewportSize.X / 2
                    local centerY = cam.ViewportSize.Y / 2
                    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
                    
                    usedClone = true
                    
                    local PlayerGui = LP:WaitForChild("PlayerGui")
                    local toolsFrames = PlayerGui:WaitForChild("ToolsFrames", 5)
                    
                    if toolsFrames and IsAlive() then
                        local qcFrame = toolsFrames:WaitForChild("QuantumCloner", 5)
                        if qcFrame and IsAlive() then
                            local tpButton = qcFrame:WaitForChild("TeleportToClone", 5)
                            
                            if tpButton then
                                -- WARTE AUF SICHTBARKEIT (Max 5s)
                                local waitUI = tick() + 5
                                while tick() < waitUI do
                                    if not IsAlive() then return end
                                    if tpButton.Visible and tpButton.AbsoluteSize.X > 0 then break end
                                    task.wait(0.1)
                                end
                                
                                if tpButton.Visible and tpButton.AbsoluteSize.X > 0 then
                                    -- WARTE BIS ANIMATION STOPPT
                                    local lastPos = tpButton.AbsolutePosition
                                    local stableCount = 0
                                    for i = 1, 40 do
                                        if not IsAlive() or not tpButton.Visible then break end
                                        task.wait(0.05)
                                        local currentPos = tpButton.AbsolutePosition
                                        if (currentPos - lastPos).Magnitude < 1 then
                                            stableCount = stableCount + 1
                                            if stableCount >= 3 then break end
                                        else
                                            stableCount = 0
                                        end
                                        lastPos = currentPos
                                    end

                                    local preSwapPos = HRP.Position
                                    
                                    -- AGGRESSIVER SPAM LOOP FÜR DEN SWAP (Macht garantiert den Klick!)
                                    local clickTimeout = tick() + 3 -- 3 Sekunden lang durchgehend spammen
                                    while tick() < clickTimeout do
                                        if not IsAlive() then break end
                                        
                                        -- Haben wir uns schon weg-teleportiert?
                                        if (HRP.Position - preSwapPos).Magnitude > 2 then
                                            didSwapInFlow = true
                                            break
                                        end
                                        
                                        -- Hat sich das Fenster geschlossen (Zeichen dass es geklappt hat)?
                                        if not tpButton.Visible then
                                            local waitServer = tick() + 1
                                            while tick() < waitServer do
                                                if (HRP.Position - preSwapPos).Magnitude > 2 then
                                                    didSwapInFlow = true
                                                    break
                                                end
                                                task.wait(0.05)
                                            end
                                            break
                                        end
                                        
                                        -- Position berechnen
                                        local absPos = tpButton.AbsolutePosition
                                        local absSize = tpButton.AbsoluteSize
                                        local inset = game:GetService("GuiService"):GetGuiInset()
                                        local clickX = absPos.X + (absSize.X / 2)
                                        local clickY = absPos.Y + (absSize.Y / 2) + inset.Y
                                        
                                        -- 1. Versuch: VIM Klick
                                        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
                                        task.wait(0.02)
                                        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
                                        
                                        -- 2. Versuch: Interne Signale (Parallel)
                                        pcall(function()
                                            if firesignal then
                                                firesignal(tpButton.Activated)
                                                firesignal(tpButton.MouseButton1Click)
                                            end
                                            if getconnections then
                                                for _, c in pairs(getconnections(tpButton.Activated)) do c:Fire() end
                                                for _, c in pairs(getconnections(tpButton.MouseButton1Click)) do c:Fire() end
                                            end
                                        end)
                                        
                                        task.wait(0.1) -- Kurz warten und direkt wieder feuern
                                    end

                                    -- NACH ERFOLGREICHEM SWAP: 0.4s WAIT (wie gewünscht) UND STABILISIERUNG
                                    if didSwapInFlow then
                                        Equip(CARPET_NAME)
                                        
                                        task.wait(0.4) -- EXAKT 0.4 SEKUNDEN WARTEN!
                                        
                                        if not IsAlive() then isRunning = false; isTpMoving = false; return end
                                        
                                        local currentPos = HRP.Position
                                        HRP.CFrame = CFrame.new(Vector3.new(currentPos.X, savedYPosition, currentPos.Z))
                                        HRP.AssemblyLinearVelocity = Vector3.zero
                                        HRP.AssemblyAngularVelocity = Vector3.zero
                                        
                                        HRP.Anchored = true
                                        task.wait(0.1)
                                        if not IsAlive() then isRunning = false; isTpMoving = false; return end
                                        HRP.Anchored = false
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        -- Teppich equippen (falls oben geskippt)
        if not didSwapInFlow then
            Equip(CARPET_NAME)
            task.wait(0.1)
        end
        if not IsAlive() then isRunning = false; isTpMoving = false; return end

        PerformVelocityFloat(targetPart)
        
        isRunning = false
        isTpMoving = false

        if Settings.TpToBrainrotAfter and usedClone and not didSwapInFlow and IsAlive() then 
            StartSwapMonitor()
        end
        return
    end
    isRunning = false
    isTpMoving = false
end

