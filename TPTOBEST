local Database = {}
local function LoadDatabase()
    pcall(function()
        local animals = ReplicatedStorage:FindFirstChild("Datas") and ReplicatedStorage.Datas:FindFirstChild("Animals")
        if animals and animals:IsA("ModuleScript") then
            local data = require(animals)
            for key, info in pairs(data) do
                if type(info) == "table" and info.Generation then
                    Database[key] = info.Generation
                    if info.DisplayName then Database[info.DisplayName] = info.Generation end
                end
            end
        end
    end)
end
