local function PerformVelocityFloat(targetPart, ignoreRagdoll)
    if not IsAlive() then return end
    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    local hum = c and c:FindFirstChildOfClass("Humanoid")
    if not hrp or not targetPart or not hum then return end
    if not ignoreRagdoll and IsRagdolled(hum) then return end

    getgenv().SMKT_DISABLE_VELOCITY = true

    local petPos = targetPart.Position
    local startY = hrp.Position.Y

    hrp.CFrame = CFrame.new(Vector3.new(petPos.X, startY, petPos.Z))
    task.wait(0.1)
    if not IsAlive() or (not ignoreRagdoll and IsRagdolled(hum)) then 
        getgenv().SMKT_DISABLE_VELOCITY = false
        return 
    end

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {c, Workspace.CurrentCamera}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local targetY      = petPos.Y
    local invisibleFloor, fConn

    local floatStart = tick()
    while tick() - floatStart < 4 do
        if not IsAlive() or (not ignoreRagdoll and IsRagdolled(hum)) then break end 
        if IsHoldingBrainrot() or LP:GetAttribute("Stealing") then break end
        if hrp.Position.Y >= targetY then
            hrp.AssemblyLinearVelocity = Vector3.zero
            break
        end

        local head = c:FindFirstChild("Head") or hrp
        local ray  = Workspace:Raycast(head.Position, Vector3.new(0, 3, 0), params)

        if ray and ray.Instance and ray.Instance.CanCollide then
            hrp.AssemblyLinearVelocity = Vector3.zero
            invisibleFloor = Instance.new("Part")
            invisibleFloor.Size        = Vector3.new(12, 1, 12)
            invisibleFloor.Position    = hrp.Position - Vector3.new(0, 3.2, 0)
            invisibleFloor.Anchored    = true
            invisibleFloor.Transparency= 1
            invisibleFloor.CanCollide  = false 
            invisibleFloor.Parent      = Workspace
            
            fConn = RunService.RenderStepped:Connect(function()
                if not invisibleFloor or not invisibleFloor.Parent then
                    if fConn then fConn:Disconnect() end
                    return
                end
                local tChar = LP.Character
                local tHrp  = tChar and tChar:FindFirstChild("HumanoidRootPart")
                if tHrp then
                    invisibleFloor.CanCollide = tHrp.Position.Y > invisibleFloor.Position.Y + 1.5
                end
            end)
            break
        end

        hrp.AssemblyLinearVelocity = Vector3.new(0, 35, 0)
        RunService.Heartbeat:Wait()
    end

    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    getgenv().SMKT_DISABLE_VELOCITY = false

    if invisibleFloor then
        task.spawn(function()
            local timeout = tick() + 15
            while tick() < timeout do
                if IsHoldingBrainrot() or LP:GetAttribute("Stealing") or not IsAlive() then break end
                task.wait(0.1)
            end
            if fConn then fConn:Disconnect() end
            pcall(function() invisibleFloor:Destroy() end)
        end)
    end
end

local function Equip(name)
    if not IsAlive() then return false end
    local c   = LP.Character
    local hum = c and c:FindFirstChildOfClass("Humanoid")
    local tool= LP.Backpack:FindFirstChild(name) or (c and c:FindFirstChild(name))
    if hum and tool then hum:EquipTool(tool) return true end
    return false
end

local function ClickTeleportToClone(tpButton)
    if not tpButton then return end
    tpButton.Visible = true

    if Settings.CloneMode == "Good" and typeof(firesignal) == "function" then
        pcall(function()
            firesignal(tpButton.MouseButton1Click)
            firesignal(tpButton.MouseButton1Up)
            firesignal(tpButton.MouseButton1Down)
        end)
    else
        local inset   = GuiService:GetGuiInset()
        local absPos  = tpButton.AbsolutePosition
        local absSize = tpButton.AbsoluteSize
        local clickX  = absPos.X + (absSize.X/2) + inset.X
        local clickY  = absPos.Y + (absSize.Y/2) + inset.Y
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
        task.wait(0.01)
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
    end
end

local function RaycastWallFromChest(maxDist)
    local c   = LP.Character
    if not c then return nil end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local origin = hrp.Position + Vector3.new(0, 0.8, 0)
    local dir    = hrp.CFrame.LookVector * maxDist

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {c, Workspace.CurrentCamera}
    params.FilterType = Enum.RaycastFilterType.Exclude

    return Workspace:Raycast(origin, dir, params)
end

local function QuickWallCheck(hum, hrp)
    if not hum or not hrp or IsRagdolled(hum) then return false end

    local startCFrame = hrp.CFrame
    local startPos    = hrp.Position

    local dir = hrp.CFrame.LookVector
    dir = Vector3.new(dir.X, 0, dir.Z)
    if dir.Magnitude < 0.1 then return false end
    dir = dir.Unit

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 0, 1e5)
    bv.Velocity = dir * 40
    bv.Parent   = hrp

    local t0       = tick()
    local duration = 0.12
    while tick() - t0 < duration do
        if not IsAlive() or IsRagdolled(hum) then break end
        RunService.Heartbeat:Wait()
    end

    bv:Destroy()

    local endPos  = hrp.Position
    local movedXZ = (Vector2.new(endPos.X, endPos.Z) - Vector2.new(startPos.X, startPos.Z)).Magnitude

    hrp.CFrame = startCFrame
    hrp.AssemblyLinearVelocity  = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    return movedXZ < 1.5
end

