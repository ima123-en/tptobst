local function OnCharacterSpawn(char)
    LastRagdollTime = 0
    AllowTpAfterRagdoll = false
    local hum = char:WaitForChild("Humanoid", 5)
    if hum then 
        savedHipHeight = hum.HipHeight 
        
        hum.StateChanged:Connect(function(old, new)
            if not Settings.TpAfterHit then return end
            if not AllowTpAfterRagdoll then return end
            if isRunning or swapMonitorActive then return end
            
            if new == Enum.HumanoidStateType.Ragdoll or new == Enum.HumanoidStateType.FallingDown or new == Enum.HumanoidStateType.Physics then
                local now = tick()
                if now - LastRagdollTime >= RagdollCooldown then
                    LastRagdollTime = now
                    
                    task.delay(0.15, function()
                        if not IsAlive() then return end
                        local h = LP.Character:FindFirstChild("Humanoid")
                        if h and IsRagdolled(h) then
                            pcall(function() h:ChangeState(Enum.HumanoidStateType.GettingUp) end)
                        end
                        TeleportToBrainrot(true) 
                    end)
                end
            end
        end)
    end
    task.delay(1.5, function() if LP.Character == char then AllowTpAfterRagdoll = true end end)
end
