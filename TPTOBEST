local function ShowNotification(text, customColor)
    local NotificationGui = LP.PlayerGui:FindFirstChild("TPNotification")
    if not NotificationGui then
        NotificationGui = Instance.new("ScreenGui")
        NotificationGui.Name = "TPNotification"
        NotificationGui.ResetOnSpawn = false
        NotificationGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        NotificationGui.DisplayOrder = 999
        NotificationGui.Parent = LP:WaitForChild("PlayerGui")

        local frame = Instance.new("Frame")
        frame.Name = "Frame"
        frame.Size = UDim2.new(0, 350, 0, 70)
        frame.Position = UDim2.new(0.5, -175, 0.08, 0)
        frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        frame.BorderSizePixel = 0
        frame.BackgroundTransparency = 1
        frame.Visible = false
        frame.Parent = NotificationGui
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)

        local label = Instance.new("TextLabel")
        label.Name = "Text"
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 22
        label.Parent = frame
    end

    local NotifFrame = NotificationGui:FindFirstChild("Frame")
    local NotifText  = NotifFrame and NotifFrame:FindFirstChild("Text")
    if not NotifFrame or not NotifText then return end

    NotifFrame.Visible = true
    NotifFrame.BackgroundTransparency = 0
    NotifText.Text            = text
    NotifText.TextTransparency = 0
    NotifText.TextColor3      = customColor or Color3.fromRGB(255, 255, 255)
    
    task.spawn(function()
        local startTime = tick()
        while tick() - startTime < 4 do
            for i = 0, 1, 0.05 do
                if not NotifFrame.Visible then break end
                local brightness = 1 - (math.sin(i * math.pi) * 0.4)
                if not customColor then
                    NotifText.TextColor3 = Color3.fromRGB(255 * brightness, 255 * brightness, 255 * brightness)
                end
                task.wait(0.03)
            end
        end
        for i = 0, 1, 0.05 do
            NotifFrame.BackgroundTransparency = i
            NotifText.TextTransparency        = i
            task.wait(0.02)
        end
        NotifFrame.Visible = false
    end)
end

