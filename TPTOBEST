local function PlaySound(id)
    task.spawn(function()
        local snd = Instance.new("Sound")
        snd.SoundId = "rbxassetid://" .. id
        snd.Volume  = 0.3
        snd.Parent  = Workspace
        snd:Play()
        snd.Ended:Wait()
        snd:Destroy()
    end)
end

local function IsAlive()
    local c   = LP.Character
    if not c then return false end
    local h   = c:FindFirstChildOfClass("Humanoid")
    local hrp = c:FindFirstChild("HumanoidRootPart")
    return h and h.Health > 0 and hrp ~= nil
end

local function IsRagdolled(h)
    if not h then return true end
    local s = h:GetState()
    return s == Enum.HumanoidStateType.Ragdoll
        or s == Enum.HumanoidStateType.Physics
        or s == Enum.HumanoidStateType.FallingDown
        or s == Enum.HumanoidStateType.Dead
end

local function IsUnderRoof()
    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    if not hrp then return true end

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {c, Workspace.CurrentCamera}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local ray = Workspace:Raycast(hrp.Position, Vector3.new(0, 100, 0), params)
    return ray and ray.Instance and ray.Instance.CanCollide or false
end

local function IsHoldingBrainrot()
    local c = LP.Character
    if not c then return false end
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and t.Name ~= CARPET_NAME and t.Name ~= TOOL_NAME then
            return true
        end
    end
    return false
end

local function getClosestBaseIdx(pos)
    local closest, dist = 1, math.huge
    for i, basePos in pairs(BASES_LOW) do
        local d = (Vector2.new(pos.X, pos.Z) - Vector2.new(basePos.X, basePos.Z)).Magnitude
        if d < dist then
            dist    = d
            closest = i
        end
    end
    return closest
end

local function findAdorneeGlobal(animalData)
    if not animalData then return nil end
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    local plot = plots:FindFirstChild(animalData.plot)
    if plot then
        local podiums = plot:FindFirstChild("AnimalPodiums")
        local podium  = podiums and podiums:FindFirstChild(animalData.slot)
        if podium then
            local base  = podium:FindFirstChild("Base")
            local spawn = base and base:FindFirstChild("Spawn")
            return spawn or (base and base:FindFirstChildWhichIsA("BasePart")) or base
        end
    end
    return nil
end

local function IsBrainrotInDuel(targetData)
    if not targetData or not targetData.plot then return false end
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return false end
    local plot = plots:FindFirstChild(targetData.plot)
    if not plot then return false end

    local ok, ch = pcall(function() return Synchronizer:Get(plot.Name) end)
    if not ok or not ch then return false end

    local owner = ch:Get("Owner")
    local ownerPlayer

    if typeof(owner) == "Instance" and owner:IsA("Player") then
        ownerPlayer = owner
    elseif typeof(owner) == "table" and owner.UserId then
        ownerPlayer = Players:GetPlayerByUserId(owner.UserId)
    elseif typeof(owner) == "table" and owner.Name then
        ownerPlayer = Players:FindFirstChild(owner.Name)
    end

    return ownerPlayer and ownerPlayer:GetAttribute("__duels_block_steal") == true
end

-------------------------------------------------
-- NUR PrioritySystem, aber mit Wait (0.5–1.5s)
-------------------------------------------------

local function GetBestTarget()
    local t0 = tick()
    local PS = getgenv().PrioritySystem

    -- Warte bis zu 1.5s, damit PRIOR‑Script laden kann
    while (not PS or not PS.SelectedData or not PS.SelectedData.plot or not PS.SelectedData.slot)
      and tick() - t0 < 1.5 do
        task.wait(0.05)
        PS = getgenv().PrioritySystem
    end

    if not PS or not PS.SelectedData or not PS.SelectedData.plot or not PS.SelectedData.slot then
        return nil, nil, false
    end

    local sel        = PS.SelectedData
    local targetPart = findAdorneeGlobal(sel)
    if not targetPart then return nil, nil, false end

    return sel, targetPart, true
end

